{
  "$schema": "https://mintlify.com/docs.json",
  "name": "ESLint Config",
  "theme": "luma",
  "colors": {
    "primary": "#4c34c4",
    "light": "#8383f3"
  },
  "favicon": "https://media.brand.dev/39f68947-c262-4dd1-a7be-e5c463a83071.svg",
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/antfu/eslint-config"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/antfu/eslint-config"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "getting-started",
              "ide-setup"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "configuration/basic",
              "configuration/stylistic",
              "configuration/typescript",
              "configuration/rules-overrides"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/vue",
              "integrations/react",
              "integrations/svelte",
              "integrations/astro",
              "integrations/angular",
              "integrations/formatters"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/customization",
              "guides/migration",
              "guides/lint-staged",
              "guides/versioning"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "API Reference",
            "pages": [
              "reference/config-options",
              "reference/exported-configs",
              "reference/plugin-renaming"
            ]
          },
          {
            "group": "FAQ",
            "pages": [
              "faq"
            ]
          }
        ]
      }
    ]
  }
}
